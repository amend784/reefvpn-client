{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReefVPN",
  "version": "1.0.0",
  "identifier": "net.reefvpn.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ReefVPN",
        "width": 320,
        "height": 580,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../resources/*"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    },
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCMUYwRDRBMzAwREIwRDUKUldUVnNBMHdTZzBmKzFyRXFud25QalJIdFd0cUZqeCtiMlNGNFhCMHBTOEoxMWVsaWJueGFCV0gK",
      "endpoints": [
        "https://reefvpn.net/api/v1/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
